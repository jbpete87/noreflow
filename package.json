{
  "name": "preflow",
  "version": "0.1.0",
  "description": "Pure TypeScript flexbox layout engine. Compute CSS-like flex layouts without DOM or browser dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "validate": "npx tsx tests/browser/validate.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "layout",
    "flexbox",
    "css",
    "flex",
    "yoga",
    "layout-engine",
    "virtual-dom",
    "canvas",
    "webgpu",
    "preflow"
  ],
  "author": "",
  "license": "MIT",
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
