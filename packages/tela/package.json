{
  "name": "tela",
  "version": "0.1.0",
  "description": "React renderer for Canvas UIs. Write JSX, render to Canvas. Powered by noreflow + Pretext + nopointer.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "react",
    "canvas",
    "renderer",
    "react-reconciler",
    "layout",
    "noreflow",
    "pretext",
    "nopointer",
    "zero-reflow",
    "ui-framework",
    "tela"
  ],
  "author": "Jake Peterson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbpete87/noreflow",
    "directory": "packages/tela"
  },
  "homepage": "https://github.com/jbpete87/noreflow/tree/main/packages/tela",
  "bugs": {
    "url": "https://github.com/jbpete87/noreflow/issues"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0",
    "noreflow": ">=0.1.0",
    "nopointer": ">=0.1.0",
    "@chenglou/pretext": ">=0.0.4"
  },
  "dependencies": {
    "react-reconciler": "^0.32.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "@types/react": "^19.1.2",
    "noreflow": "workspace:*",
    "nopointer": "workspace:*",
    "@chenglou/pretext": "^0.0.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
