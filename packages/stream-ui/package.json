{
  "name": "@noreflow/stream-ui",
  "version": "0.1.0",
  "description": "Zero-reflow streaming UI components. Canvas-rendered chat built on noreflow + pretext.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "streaming",
    "chat",
    "canvas",
    "layout",
    "noreflow",
    "pretext",
    "zero-reflow",
    "ai-chat",
    "virtual-scroll"
  ],
  "author": "Jake Peterson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbpete87/noreflow",
    "directory": "packages/stream-ui"
  },
  "homepage": "https://github.com/jbpete87/noreflow/tree/main/packages/stream-ui",
  "bugs": {
    "url": "https://github.com/jbpete87/noreflow/issues"
  },
  "peerDependencies": {
    "noreflow": ">=0.1.0",
    "@chenglou/pretext": ">=0.0.3",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "noreflow": "workspace:*",
    "@chenglou/pretext": "^0.0.3",
    "react": "^19.1.0",
    "@types/react": "^19.1.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
