{
  "name": "nopointer",
  "version": "0.1.0",
  "description": "Pure TypeScript hit-testing + pointer event system. Spatial queries, gesture recognition, and event propagation for Canvas/WebGPU UIs. No DOM.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "hit-testing",
    "pointer-events",
    "gesture-recognition",
    "canvas",
    "webgpu",
    "event-system",
    "spatial-query",
    "noreflow",
    "nopointer",
    "ui-framework"
  ],
  "author": "Jake Peterson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbpete87/noreflow",
    "directory": "packages/nopointer"
  },
  "homepage": "https://github.com/jbpete87/noreflow/tree/main/packages/nopointer",
  "bugs": {
    "url": "https://github.com/jbpete87/noreflow/issues"
  },
  "sideEffects": false,
  "peerDependencies": {
    "noreflow": ">=0.1.0"
  },
  "devDependencies": {
    "noreflow": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
